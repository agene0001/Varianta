# Google AI Studio API key — get one free at https://aistudio.google.com/apikey
# Required only if you want AI-generated move descriptions in the Lichess Importer.
# Without a key, imported lines still work but get mechanical placeholder descriptions.
VITE_GEMINI_API_KEY=

# Gemini model to use. Override if you want a different model.
# Defaults to gemini-3.5-flash inside the app if unset.
VITE_GEMINI_MODEL=gemini-3.5-flash

# Optional — Lichess personal API token. Without it, the position explorer falls
# back to chessdb.cn (engine eval + estimated winrate). With it, the explorer
# can also query Lichess game stats (white wins / draws / black wins / total games)
# and the Masters database. Get a free token at https://lichess.org/account/oauth/token
# (no scopes required for the opening explorer).
VITE_LICHESS_TOKEN=
